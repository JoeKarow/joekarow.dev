---
interface Props {
	text: string
	href: string
}

const { text, href } = Astro.props
---

<section id={href} class='py-24' aria-labelledby={`${href}-heading`}>
	<h2
		id={`${href}-heading`}
		class='mb-14 font-serif text-4xl font-bold tracking-tighter text-white md:text-5xl'
	>
		{text}
	</h2>
	<slot />
</section>
